{
  "family": "nodejs-devops",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "ECS_EXECUTION_ROLE_ARN",
  "containerDefinitions": [
    {
      "name": "nodejs-app",
      "image": "ACCOUNT_ID.dkr.ecr.ap-south-1.amazonaws.com/nodejs-devops:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/nodejs-devops",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}